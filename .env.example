# Copy this to .env and fill in your keys

# Anthropic (Claude) - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Outscraper - get from outscraper.com (500 free leads/mo → $3/1000 after)
OUTSCRAPER_API_KEY=

# Hunter.io - get from hunter.io (50 free domain email searches/mo)
# Used to find emails when scraper can't extract them
HUNTER_API_KEY=

# Apify - get from apify.com (~$5 free credits/month)
# Used for Instagram lead scraping (residential proxies built-in)
APIFY_API_KEY=

# Google Sheets - ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=

# Path to your Google service account JSON file
# Create at: console.cloud.google.com → APIs → Credentials → Service Account
GOOGLE_SERVICE_ACCOUNT_JSON=/Users/jainarnav/leadgen/service_account.json
